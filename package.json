    "test": "npm run test --workspace=balance",
    "typecheck": "npm run typecheck --workspace=balance",
    "format": "npm run format --workspace=balance",
    "format:check": "npm run format:check --workspace=balance",
    "codegen": "npm run codegen --workspace=balance",
    "sandcastle": "npx tsx .sandcastle/main.mts"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.11"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
